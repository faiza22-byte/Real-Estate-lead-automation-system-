        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ model: \"gpt-4o-mini\", messages: [ { role: \"system\", content: \"Summarize this lead qualification call and extract: type (buyer/seller), budget, location, timeline, financing status. Respond with ONLY valid JSON, no markdown, matching this shape: {\\\"type\\\":\\\"\\\",\\\"budget\\\":\\\"\\\",\\\"location\\\":\\\"\\\",\\\"timeline\\\":\\\"\\\",\\\"financing\\\":\\\"\\\",\\\"interested\\\":true,\\\"summary\\\":\\\"\\\"}\" }, { role: \"user\", content: ($('Voice Agent Return Webhook').item.json.body?.message?.transcript || $('Voice Agent Return Webhook').item.json.body?.message?.analysis?.summary || $('Voice Agent Return Webhook').item.json.body?.transcript || \"No transcript was available for this call.\") } ], temperature: 0.2 }) }}",
        "options": {}
      },
      "id": "summarize-call-openai-id",
      "name": "Summarize Call (OpenAI)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        51552,
        23472
      ],
      "credentials": {
        "openAiApi": {
