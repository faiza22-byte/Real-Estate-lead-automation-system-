          "name": "OpenAI account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const vapiMsg = $('Voice Agent Return Webhook').item.json.body?.message || {};\nconst call = vapiMsg.call || {};\nconst meta = call.assistantOverrides?.metadata || call.metadata || call.assistant?.metadata || {};\nconst raw = $input.item.json.choices?.[0]?.message?.content || '';\nlet parsed;\ntry {\n  const cleaned = raw.replace(/```json|```/g, '').trim();\n  parsed = JSON.parse(cleaned);\n} catch (e) {\n  parsed = { type: '', budget: '', location: '', timeline: '', financing: '', interested: false, summary: raw };\n}\nlet budget = parsed.budget || '';\nif (typeof budget === 'string') {\n  budget = budget.replace(/[$,]/g, '').replace(/million/i, '000000').replace(/m/i, '000000');\n}\nbudget = Number(budget) || null;\nreturn [{ json: { airtableRecordId: meta.airtableRecordId || meta.recordId || '', email: meta.email || '', name: meta.name || '', type: parsed.type || '', budget: budget, location: parsed.location || '', timeline: parsed.timeline || '', financing: parsed.financing || '', interested: parsed.interested === true, summary: parsed.summary || '' } }];"
      },
